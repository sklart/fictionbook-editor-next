    LTEXT           "Профиль оформления:",IDC_LBL_STYLE_PROFILE,30,142,100,8
    COMBOBOX        IDC_STYLE_PROFILE,140,138,150,60,CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
