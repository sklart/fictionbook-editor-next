    PUSHBUTTON      "Редакторский",IDC_PRESET_EDITORIAL,310,50,90,14
    CONTROL         "Выравнивать основной текст по ширине",IDC_JUSTIFY_TEXT,"Button",BS_AUTOCHECKBOX | WS_TABSTOP,30,72,230,10
    CONTROL         "Делать отступ первой строки",IDC_FIRST_LINE_INDENT,"Button",BS_AUTOCHECKBOX | WS_TABSTOP,30,88,220,10
