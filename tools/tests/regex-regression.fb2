	<body>
		<title>
			<p>Регрессия регулярных выражений</p>
		</title>
		<section>
			<title><p>Скобки и числа</p></title>
			<p>(1) 1 (22) 22</p>
			<p>(333) 333 (4444) 4444</p>
		</section>
		<section>
			<title><p>Латиница и регистр</p></title>
			<p>alpha beta alpha</p>
			<p>alpha beta ALPHA</p>
			<p>ivan IVAN Ivan</p>
			<p>abcd</p>
		</section>
		<section>
			<title><p>Кириллица и регистр</p></title>
			<p>я</p>
			<p>привет</p>
			<p>иван</p>
			<p>ИВАН</p>
			<p>Ёж ёж ЕЛЬ ель</p>
		</section>
		<section>
			<title><p>Необязательные и пустые группы</p></title>
			<p>b ab aab</p>
			<p>bbb</p>
		</section>
		<section>
			<title><p>Многострочный блок</p></title>
			<p>alpha</p>
			<p>beta</p>
			<p>gamma</p>
		</section>
		<section>
			<title><p>XML-фрагмент для режима Код</p></title>
